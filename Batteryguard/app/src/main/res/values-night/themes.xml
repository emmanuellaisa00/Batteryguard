<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BatteryGuard" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">#04040F</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
    <style name="Theme.BatteryGuard.Overlay" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">#04040F</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">#04040F</item>
        <item name="android:navigationBarColor">#04040F</item>
    </style>
</resources>
